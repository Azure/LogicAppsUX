    {
        /// <summary>
        /// Initializes workflow.
        /// </summary>
        [WorkflowInitialization]
        public static void InitializeCodefulWorkflows()
        {
            Console.WriteLine("Creating a workflow definition InitializeCodefulWorkflows net8");

            var workflowBuilder = WorkflowAgentBuilderFactory.CreateWorkflowAgentBuilder("newFlow");
            var agent = new AgentBuilder
            {
                AgentModelType = AgentModelType.AzureOpenAI,
                DeploymentId = "gpt-4.1",
                AgentModelSettings = new AgentModelSettings
                {
                    AgentChatCompletionSettings = new AgentChatCompletionSettings
                    {
                        MaxTokens = 1000,
                        Temperature = 0.7,
                    },
                    DeploymentModelProperties = new AgentDeploymentModelProperties
                    {
                        Format = "OpenAI",
                        Version = "2025-04-14",
                        Name = "gpt-4.1",
                    }
                },
                Messages = new AgentPromptMessage[]
                    {
                    new AgentPromptMessage
                    {
                        Role = MessageRole.System,
                        Content = "You are a helpful assistant that sends a message to service bus."
                    }
                    },
                ConnectionName = "agent-2",
            };
            var toolBuilder = new AgentTool<MyObject>();

            agent.AddTool(b =>
            {
                var action = b.GetManagedConnectors().Msnweather.CurrentWeatherAsync("connectionid", location => "WA", units: b1 => "Celsius");
                b.AddAction(action);
            },
            description: "Test",
            parameters: new MyObject());

            workflowBuilder.AddAgent(() => agent);
            workflowBuilder.BuildConversationalFlow();

            Console.WriteLine("Workflow Template (JSON):\n" + workflowBuilder.GetFlowDefinition().Kind);
        }

        /// <summary>
        /// My object class.
        /// </summary>
        public class MyObject
        {
            /// <summary>
            /// x property.
            /// </summary>
            public int X { get; set; }
        }
    }
